---
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
  <!-- Animated gradient background -->
  <div class="absolute inset-0 hero-gradient"></div>

  <!-- Floating orbs -->
  <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-violet/10 rounded-full blur-3xl animate-float"></div>
  <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-gold/5 rounded-full blur-3xl animate-float" style="animation-delay: -3s;"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-deep-violet/5 rounded-full blur-3xl animate-glow-pulse"></div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 hero-grid opacity-[0.03]"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Gold accent line -->
    <div class="mx-auto w-16 h-1 bg-gradient-to-r from-transparent via-gold to-transparent mb-8 animate-fade-in"></div>

    <!-- App name -->
    <h1 class="font-heading font-extrabold text-6xl sm:text-7xl md:text-8xl lg:text-9xl tracking-tight mb-6 animate-fade-in">
      <span class="bg-clip-text text-transparent bg-gradient-to-b from-purple-mist via-purple-mist to-purple-mist/60">
        UNJYNX
      </span>
    </h1>

    <!-- Tagline -->
    <p class="font-heading font-semibold text-xl sm:text-2xl md:text-3xl text-gold mb-6 animate-slide-up" style="animation-delay: 0.2s;">
      Break the satisfactory. Unjynx your productivity.
    </p>

    <!-- Subtitle -->
    <p class="font-body text-lg sm:text-xl text-purple-mist/60 max-w-2xl mx-auto mb-12 animate-slide-up" style="animation-delay: 0.4s;">
      The only TODO app that reminds you on WhatsApp, Telegram, Instagram, SMS, and more.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 0.6s;">
      <a
        href="#"
        data-ph-capture="true"
        data-ph-capture-attribute-button="cta-app-store"
        class="group flex items-center gap-3 px-8 py-4 bg-gold text-midnight font-heading font-bold text-base rounded-full hover:bg-rich-gold hover:scale-105 transition-all duration-300 shadow-lg shadow-gold/20"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        Download on App Store
      </a>
      <a
        href="#"
        data-ph-capture="true"
        data-ph-capture-attribute-button="cta-google-play"
        class="group flex items-center gap-3 px-8 py-4 border-2 border-violet text-purple-mist font-heading font-bold text-base rounded-full hover:bg-violet/10 hover:border-gold hover:text-gold hover:scale-105 transition-all duration-300"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-1.4l2.834 1.64a1 1 0 0 1 0 1.74l-2.834 1.64-2.532-2.533 2.532-2.488zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/>
        </svg>
        Get it on Google Play
      </a>
    </div>

    <!-- Social proof hint -->
    <div class="mt-16 flex items-center justify-center gap-6 animate-slide-up" style="animation-delay: 0.8s;">
      <div class="flex -space-x-3">
        {[0,1,2,3,4].map((i) => (
          <div
            class="w-10 h-10 rounded-full border-2 border-midnight flex items-center justify-center text-sm font-bold"
            style={`background: linear-gradient(135deg, hsl(${260 + i * 20}, 70%, ${40 + i * 5}%), hsl(${280 + i * 20}, 60%, ${30 + i * 5}%));`}
          >
            {String.fromCharCode(65 + i)}
          </div>
        ))}
      </div>
      <p class="font-body text-sm text-purple-mist/50">
        Join <span class="text-gold font-semibold">2,000+</span> early access users
      </p>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-purple-mist/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  .hero-gradient {
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(108, 92, 231, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 70% 100%, rgba(255, 215, 0, 0.05) 0%, transparent 50%),
      radial-gradient(ellipse 40% 40% at 20% 60%, rgba(107, 33, 168, 0.08) 0%, transparent 50%);
  }

  .hero-grid {
    background-image:
      linear-gradient(rgba(248, 245, 255, 1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(248, 245, 255, 1) 1px, transparent 1px);
    background-size: 60px 60px;
  }
</style>
