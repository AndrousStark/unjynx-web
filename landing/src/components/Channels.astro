---
const channels = [
  { name: 'WhatsApp', color: '#25D366', letter: 'W' },
  { name: 'Telegram', color: '#0088CC', letter: 'T' },
  { name: 'Instagram', color: '#E4405F', letter: 'I' },
  { name: 'SMS', color: '#FFD700', letter: 'S' },
  { name: 'Discord', color: '#5865F2', letter: 'D' },
  { name: 'Slack', color: '#4A154B', letter: 'Sl' },
  { name: 'Email', color: '#6C5CE7', letter: 'E' },
];
---

<section id="channels" class="relative py-24 sm:py-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-b from-midnight via-midnight to-midnight"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-violet/[0.03] rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16 sm:mb-20 reveal">
      <p class="font-body text-sm font-semibold text-gold uppercase tracking-widest mb-4">
        7 Channels
      </p>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl md:text-5xl text-purple-mist mb-6">
        Your reminders. Your channels.<br />
        <span class="text-gold">Your way.</span>
      </h2>
      <p class="font-body text-lg text-purple-mist/50 max-w-2xl mx-auto">
        UNJYNX reaches you wherever you are. Set up escalation chains so you never miss what matters.
      </p>
    </div>

    <!-- Channel visualization -->
    <div class="relative max-w-4xl mx-auto reveal">
      <!-- Connection lines (CSS) -->
      <div class="channels-visual relative flex flex-col items-center gap-12 lg:gap-0 lg:flex-row lg:justify-between lg:items-center">

        <!-- Left channels -->
        <div class="flex flex-wrap justify-center gap-4 lg:flex-col lg:gap-6 lg:w-1/3">
          {channels.slice(0, 3).map((channel) => (
            <div class="channel-node group flex items-center gap-3">
              <div
                class="w-14 h-14 sm:w-16 sm:h-16 rounded-2xl flex items-center justify-center font-heading font-bold text-lg text-white shadow-lg transition-transform duration-300 group-hover:scale-110"
                style={`background: ${channel.color}; box-shadow: 0 0 30px ${channel.color}33;`}
              >
                {channel.letter}
              </div>
              <span class="hidden lg:block font-body text-sm text-purple-mist/60 group-hover:text-purple-mist transition-colors">
                {channel.name}
              </span>
            </div>
          ))}
        </div>

        <!-- Center phone mockup -->
        <div class="relative lg:w-1/3 flex justify-center">
          <!-- Phone frame -->
          <div class="relative w-48 h-80 sm:w-56 sm:h-96 rounded-[2.5rem] border-2 border-violet/30 bg-midnight-light/80 backdrop-blur-sm overflow-hidden shadow-2xl shadow-violet/10">
            <!-- Screen -->
            <div class="absolute inset-3 rounded-[2rem] bg-gradient-to-b from-midnight-lighter to-midnight overflow-hidden">
              <!-- Status bar -->
              <div class="flex items-center justify-between px-4 pt-3 pb-2">
                <span class="font-body text-[10px] text-purple-mist/40">9:41</span>
                <div class="flex gap-1">
                  <div class="w-3 h-1.5 rounded-sm bg-purple-mist/30"></div>
                  <div class="w-3 h-1.5 rounded-sm bg-purple-mist/30"></div>
                  <div class="w-3 h-1.5 rounded-sm bg-gold/60"></div>
                </div>
              </div>
              <!-- App content mockup -->
              <div class="px-4 pt-2">
                <div class="font-heading font-bold text-sm text-gold mb-3">UNJYNX</div>
                <div class="space-y-2">
                  <div class="flex items-center gap-2 p-2 rounded-lg bg-violet/10">
                    <div class="w-4 h-4 rounded-full bg-gold/80"></div>
                    <div class="flex-1 h-2 rounded bg-purple-mist/20"></div>
                  </div>
                  <div class="flex items-center gap-2 p-2 rounded-lg bg-violet/5">
                    <div class="w-4 h-4 rounded-full border border-violet/30"></div>
                    <div class="flex-1 h-2 rounded bg-purple-mist/10"></div>
                  </div>
                  <div class="flex items-center gap-2 p-2 rounded-lg bg-violet/5">
                    <div class="w-4 h-4 rounded-full border border-violet/30"></div>
                    <div class="flex-1 h-2 rounded bg-purple-mist/10 w-3/4"></div>
                  </div>
                  <div class="flex items-center gap-2 p-2 rounded-lg bg-violet/5">
                    <div class="w-4 h-4 rounded-full border border-violet/30"></div>
                    <div class="flex-1 h-2 rounded bg-purple-mist/10 w-1/2"></div>
                  </div>
                </div>
                <!-- Reminder notification -->
                <div class="mt-4 p-3 rounded-xl bg-gradient-to-r from-violet/20 to-gold/10 border border-violet/20">
                  <div class="font-body text-[10px] text-gold mb-1">Reminder sent via WhatsApp</div>
                  <div class="font-body text-[9px] text-purple-mist/40">Meeting with design team in 15 min</div>
                </div>
              </div>
            </div>

            <!-- Notch -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-5 bg-midnight rounded-b-2xl"></div>
          </div>

          <!-- Pulse rings -->
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class="w-64 h-64 rounded-full border border-violet/10 animate-glow-pulse"></div>
            <div class="absolute w-80 h-80 rounded-full border border-violet/5 animate-glow-pulse" style="animation-delay: -1.5s;"></div>
          </div>
        </div>

        <!-- Right channels -->
        <div class="flex flex-wrap justify-center gap-4 lg:flex-col lg:gap-6 lg:items-end lg:w-1/3">
          {channels.slice(3).map((channel) => (
            <div class="channel-node group flex items-center gap-3 lg:flex-row-reverse">
              <div
                class="w-14 h-14 sm:w-16 sm:h-16 rounded-2xl flex items-center justify-center font-heading font-bold text-lg text-white shadow-lg transition-transform duration-300 group-hover:scale-110"
                style={`background: ${channel.color}; box-shadow: 0 0 30px ${channel.color}33;`}
              >
                {channel.letter}
              </div>
              <span class="hidden lg:block font-body text-sm text-purple-mist/60 group-hover:text-purple-mist transition-colors">
                {channel.name}
              </span>
            </div>
          ))}
        </div>
      </div>

      <!-- Channel names for mobile -->
      <div class="mt-8 flex flex-wrap justify-center gap-3 lg:hidden">
        {channels.map((channel) => (
          <span class="font-body text-xs text-purple-mist/40 px-3 py-1 rounded-full border border-white/5">
            {channel.name}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
