---
const features = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
    </svg>`,
    title: 'Multi-Channel Reminders',
    description: 'Get reminded on WhatsApp, Telegram, Instagram, SMS, Discord, Slack, and Email. Your tasks follow you where you already are.',
    accent: 'from-green-400 to-emerald-600',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09zM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456zM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423z" />
    </svg>`,
    title: 'Smart Scheduling',
    description: 'AI-powered task scheduling that learns your energy patterns, peak hours, and habits. Let the algorithm optimize your day.',
    accent: 'from-violet to-deep-violet',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12c1.292 4.338 5.31 7.5 10.066 7.5.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
    </svg>`,
    title: 'Ghost Mode',
    description: 'Enter distraction-free deep focus. Block apps, silence notifications, and let your team know you are in the zone. Productivity, unjynxed.',
    accent: 'from-slate-400 to-slate-600',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
    </svg>`,
    title: 'Daily Wisdom',
    description: 'Start each day with curated quotes from history\'s greatest minds. Mahabharata, Stoics, innovators. 60+ categories of inspiration.',
    accent: 'from-amber-400 to-orange-600',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125z" />
    </svg>`,
    title: 'Progress Dashboard',
    description: 'Strava-like analytics for your productivity. Streak rings, heatmaps, personal bests, and weekly insights that actually motivate.',
    accent: 'from-blue-400 to-cyan-600',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
    </svg>`,
    title: 'Cross-Platform',
    description: 'Works seamlessly on Android, iOS, Apple Watch, and Wear OS. Your tasks sync everywhere, offline-first with conflict-free resolution.',
    accent: 'from-purple-400 to-fuchsia-600',
  },
];
---

<section id="features" class="relative py-24 sm:py-32">
  <!-- Background accent -->
  <div class="absolute inset-0 bg-gradient-to-b from-midnight via-midnight-light/50 to-midnight"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16 sm:mb-20 reveal">
      <p class="font-body text-sm font-semibold text-gold uppercase tracking-widest mb-4">
        Why UNJYNX
      </p>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl md:text-5xl text-purple-mist mb-6">
        Everything you need.<br />
        <span class="text-violet">Nothing you don't.</span>
      </h2>
      <p class="font-body text-lg text-purple-mist/50 max-w-2xl mx-auto">
        Six powerful features that transform how you manage tasks, stay focused, and actually get things done.
      </p>
    </div>

    <!-- Feature grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 reveal-children">
      {features.map((feature) => (
        <div class="group relative p-8 rounded-2xl border border-violet/10 bg-midnight-light/30 backdrop-blur-sm hover:border-violet/30 hover:bg-midnight-light/50 transition-all duration-500">
          <!-- Gradient glow on hover -->
          <div class={`absolute inset-0 rounded-2xl bg-gradient-to-br ${feature.accent} opacity-0 group-hover:opacity-[0.03] transition-opacity duration-500`}></div>

          <div class="relative z-10">
            <!-- Icon -->
            <div class="w-14 h-14 rounded-xl bg-violet-dim flex items-center justify-center text-violet mb-6 group-hover:text-gold transition-colors duration-300">
              <Fragment set:html={feature.icon} />
            </div>

            <!-- Title -->
            <h3 class="font-heading font-semibold text-xl text-purple-mist mb-3 group-hover:text-gold transition-colors duration-300">
              {feature.title}
            </h3>

            <!-- Description -->
            <p class="font-body text-sm leading-relaxed text-purple-mist/50 group-hover:text-purple-mist/70 transition-colors duration-300">
              {feature.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
